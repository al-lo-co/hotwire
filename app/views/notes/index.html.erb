<!-- app/views/notes/index.html.erb -->
<h1>Notas</h1>

<!-- Formulario para crear una nueva nota -->
<%= form_with model: Note.new, data: { controller: "notes", action: "turbo:submit-end->notes#create" } do |form| %>
  <div class="form-group">
    <%= form.label :title %>
    <%= form.text_field :title, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :content %>
    <%= form.text_area :content, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.submit "Crear nota", class: "btn btn-primary" %>
  </div>
<% end %>

<!-- Lista de notas -->
<div id="notes">
  <%= turbo_frame_tag 'notes' do %>
    <% @notes.each do |note| %>
      <div id="note_<%= note.id %>" class="note">
        <h3 class="note-title"><%= note.title %></h3>
        <p class="note-content"><%= note.content %></p>
      </div>
    <% end %>
  <% end %>
</div>
